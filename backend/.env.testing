APP_NAME=Laravel
APP_ENV=testing
APP_DEBUG=true
APP_URL=http://localhost:8000

# ============================================================
# TESTING DATABASE — Uses SQLite in-memory, NOT your real DB
# This file ensures tests NEVER touch the MySQL Cliberduche DB
# ============================================================
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
BROADCAST_CONNECTION=null

BCRYPT_ROUNDS=4

SANCTUM_STATEFUL_DOMAINS=localhost
